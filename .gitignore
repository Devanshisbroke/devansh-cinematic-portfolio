# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared
build/
out/

# Dependencies
node_modules
.pnpm-store/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
testem.log

# Env / secrets — never commit these
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.keystore

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.sublime-project

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
/typings

# System Files
.DS_Store
Thumbs.db
desktop.ini

# Tooling-specific
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit (IDE-specific scratch space; not part of the source build)
.cache/
.local/
.upm/
attached_assets/
replit.md

# Test + coverage artefacts
coverage/
.nyc_output/

# Build output (root + per-package)
**/dist/
**/build/
artifacts/portfolio/dist/
artifacts/api-server/dist/
artifacts/mockup-sandbox/dist/

# Generated source maps in production builds
*.map

# OS-generated
ehthumbs.db
ehthumbs_vista.db
